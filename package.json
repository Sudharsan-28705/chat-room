{
  "name": "hanaso",
  "version": "1.0.0",
  "private": true,
  "description": "Hanaso! - Production-ready language learning chat app",
  "scripts": {
    "dev": "concurrently \"npm run client:dev\" \"npm run server:dev\"",
    "client:dev": "cd client && npm run dev",
    "server:dev": "cd server && npm run dev",
    "build": "npm run client:build",
    "preview": "npm run client:preview"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "dependencies": {
    "moment": "^2.30.1"
  }
}
